pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
#include util.lua
#include body.lua
#include hitbox.lua
#include system.lua
#include player.lua
#include zombie.lua
#include bat.lua
#include knight.lua
#include skeleton.lua
#include room.lua

function _init()
	room_map = {}
	for rx = 0, 7 do
		for ry = 0, 3 do
			local key = rx .. "," .. ry
			room_map[key] = room_load(rx, ry)
		end
	end

	player = player_new(16 + 128, 48 + 80 - 40)
	room = room_map["0,1"]
	room.init(player)
	state = "play"
end

function _update()
	if state == "play" then
		local result = room.update()
		if not result then
		elseif result.rx and result.ry then
			room = room_map[result.rx .. "," .. result.ry]
			room.init(player)
		elseif result.dead then
			state = "dead"
		end
	end
end

function _draw()
	cls()
	room.draw()
end

