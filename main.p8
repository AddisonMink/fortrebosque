pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
#include system.lua
#include behavior.lua
#include player.lua
#include zombie.lua








entities = { player, zombie }

function _init()
	camera(0,-8)
end

function _update()
	for e in all(entities) do
		if e.update then
			e.update(e,entities)
		end
	end

	for e in all(entities) do
		if e.body then
			update_body(e.body)
		end
	end
end

function _draw()
	cls()
	map()
	
	for e in all(entities) do
	 if e.draw then
	 	e.draw(e)
	 end
	end

	local player = entities[1]
	local y = -8
	local x = print("hp", 1,y,8)
	for i = 1, player.hitbox.hp_max do
		x = print("♥", x, y, i <= player.hitbox.hp and 8 or 2 )
	end
end
-->8



